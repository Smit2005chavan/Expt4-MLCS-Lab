# =============================================================
print("\n1. DATA SOURCES:")

# ── Load Exp 3 dataset (Kaggle) ─────────────────────────────
exp3_df = pd.read_csv('phishing.csv')   # change path if needed

print(f"   Exp 3 (Kaggle): {len(exp3_df):,} samples, "
      f"{len(exp3_df.columns)-2} features")
print(f"   Tools: Kaggle API, pandas")

# ── Generate Exp 4 Dataset (Real-Time Simulation) ───────────
# Exactly as in original writeup:
# Sample 1470 phishing + 2030 legitimate from Exp 3
phishing   = exp3_df[exp3_df['class'] == -1].sample(
    1470, replace=True)
legitimate = exp3_df[exp3_df['class'] ==  1].sample(
    2030, replace=True)

# Add noise to simulate real-world data variation
feature_cols = [col for col in exp3_df.columns
                if col not in ['Index', 'class']]

for df_part in [phishing, legitimate]:
    for col in feature_cols:
        if np.random.random() < 0.3:
            # Small noise: -1, 0, or +1 (weighted to keep 0)
            noise = np.random.choice(
                [-1, 0, 1],
                size=len(df_part),
                p=[0.15, 0.70, 0.15]
            )
            df_part[col] = (df_part[col] + noise).clip(-1, 1)

# Combine phishing + legitimate, shuffle
exp4_df = pd.concat([phishing, legitimate], ignore_index=True)
exp4_df = exp4_df.sample(
    frac=1, random_state=42).reset_index(drop=True)

print(f"   Exp 4 (Generated): {len(exp4_df):,} samples")

# =============================================================
# 2. RATIONALE
# =============================================================
print("\n2. RATIONALE:")
print("   Exp 3: Baseline from Kaggle (large, comprehensive)")
print("   Exp 4: Test robustness on new patterns with noise")
print("   Goal : Compare old vs recent data performance")

# =============================================================
# 3. QUALITY INSPECTION
# =============================================================
print("\n3. QUALITY ISSUES:")

def inspect(df, name):
    missing    = df.isnull().sum().sum()
    duplicates = df.duplicated().sum()
    balance    = (min(df['class'].value_counts()) /
                  max(df['class'].value_counts()))
    print(f"   {name}:")
    print(f"   - Missing   : {missing}")
    print(f"   - Duplicates: {duplicates:,} "
          f"({duplicates/len(df)*100:.1f}%)")
    print(f"   - Balance   : {balance:.2f}")
    return missing, duplicates

miss3, dup3 = inspect(exp3_df, "Exp 3")
miss4, dup4 = inspect(exp4_df, "Exp 4")

# =============================================================
# 4. DATA CLEANING
# =============================================================
print("\n4. CLEANING APPLIED:")

def clean(df, name):
    original_size = len(df)

    # Drop Index column (not a feature)
    if 'Index' in df.columns:
        df = df.drop('Index', axis=1)

    # Remove duplicate rows
    df = df.drop_duplicates()
    cleaned_size = len(df)
    removed      = original_size - cleaned_size

    # Binary label: -1 → 0 (phishing),  +1 → 1 (legitimate)
    df['class_binary'] = df['class'].apply(
        lambda x: 0 if x == -1 else 1)

    print(f"   {name}: {original_size:,} → {cleaned_size:,} "
          f"({removed:,} removed)")
    return df, removed

exp3_clean, removed3 = clean(exp3_df.copy(), "Exp 3")
exp4_clean, removed4 = clean(exp4_df.copy(), "Exp 4")
print("   Techniques: Drop Index, Remove duplicates, Binary labels")

FEATURE_COLS = [c for c in exp3_clean.columns
                if c not in ['class', 'class_binary']]

# =============================================================
# 5. FEATURE ANALYSIS (RF Importance)
# =============================================================
print("\n5. FEATURE ANALYSIS:")

def analyze(df, name):
    features = [c for c in df.columns
                if c not in ['class', 'class_binary']]
    X  = df[features]
    y  = df['class_binary']

    rf = RandomForestClassifier(
        n_estimators=50, random_state=42, n_jobs=-1)
    rf.fit(X, y)

    imp_df = pd.DataFrame({
        'Feature':    features,
        'Importance': rf.feature_importances_
    }).sort_values('Importance', ascending=False)

    print(f"   {name} Top 5:")
    for _, row in imp_df.head(5).iterrows():
        print(f"     {row['Feature']:<25} {row['Importance']:.4f}")

    return imp_df

imp3 = analyze(exp3_clean, "Exp 3")
imp4 = analyze(exp4_clean, "Exp 4")

# ── Novel: Assign attack type to each phishing URL ──────────
phishing_df = exp3_clean[exp3_clean['class'] == -1].copy()
phishing_df = phishing_df.reset_index(drop=True)

def assign_attack_type(row):
    """
    Maps each phishing URL to 1 of 6 attack subtypes
    based on which URL features are activated.
    """
    score = {
        'IP-Based\n(Pharming)':
            int(row['UsingIP']       ==  1) +
            int(row['AbnormalURL']   ==  1) +
            int(row['DNSRecording']  == -1),

        'HTTPS Spoofing\n(Clone)':
            int(row['HTTPS']          == -1) +
            int(row['HTTPSDomainURL'] == -1) +
            int(row['Favicon']        ==  1),

        'Redirection\n(Watering Hole)':
            int(row['Redirecting//']     ==  1) +
            int(row['WebsiteForwarding'] ==  1) +
            int(row['IframeRedirection'] ==  1),

        'URL Obfuscation\n(Typosquatting)':
            int(row['LongURL']       ==  1) +
            int(row['PrefixSuffix-'] == -1) +
            int(row['SubDomains']    ==  1) +
            int(row['ShortURL']      ==  1),

        'Social Engineering\n(Spear)':
            int(row['AnchorURL']         == -1) +
            int(row['InfoEmail']         ==  1) +
            int(row['RequestURL']        == -1) +
            int(row['ServerFormHandler'] == -1),

        'SEO Poisoning\n(Search Engine)':
            int(row['GoogleIndex']    == -1) +
            int(row['WebsiteTraffic'] == -1) +
            int(row['PageRank']       == -1) +
            int(row['StatsReport']    == -1),
    }
    best = max(score, key=score.get)
    return best if score[best] > 0 else 'SEO Poisoning\n(Search Engine)'

phishing_df['attack_type'] = phishing_df.apply(
    assign_attack_type, axis=1)
attack_counts = phishing_df['attack_type'].value_counts()

