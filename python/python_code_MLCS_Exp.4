    'LongURL', 'AbnormalURL', 'InfoEmail', 'GoogleIndex'
]
N      = len(radar_features)
angles = [n / float(N) * 2 * np.pi for n in range(N)]
angles += angles[:1]

fig, ax = plt.subplots(figsize=(8, 8),
                       subplot_kw=dict(polar=True))
